*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘Barlow’, sans-serif;
padding: 2.5rem 2rem 4rem;
transition: background 0.2s, color 0.2s;
}

/* ── Header ── */
header {
display: flex;
align-items: center;
gap: 1.1rem;
margin-bottom: 2.5rem;
}

.palette-logo { flex-shrink: 0; width: 54px; height: 54px; }

h1 {
font-family: ‘Barlow Condensed’, sans-serif;
font-size: 1.9rem; font-weight: 700;
text-transform: uppercase; letter-spacing: 0.04em;
color: var(–wmp-blue); line-height: 1;
}

@media (prefers-color-scheme: dark) {
h1 { color: #8ab4e8; }
}

h1 span {
display: block; font-size: 0.9rem; font-weight: 600;
color: var(–text-mid); letter-spacing: 0.12em;
text-transform: uppercase; margin-top: 0.3rem;
}

/* ── Section label ── */
.section-label {
font-family: ‘Barlow Condensed’, sans-serif;
font-size: 1.05rem; font-weight: 700;
text-transform: uppercase; letter-spacing: 0.14em;
color: var(–section-label-text);
margin: 2.25rem 0 0.9rem;
padding-bottom: 0.45rem;
border-bottom: 3px solid var(–wmp-yellow);
display: inline-block;
}

/* ── Colour group ── */
.colour-group {
background: var(–surface);
border-radius: 10px;
overflow: hidden;
box-shadow: none;
margin-bottom: 1.1rem;
border: 2px solid var(–border);
}

/* ── Collapsible header ── */
.group-header {
display: flex;
align-items: center;
gap: 1rem;
padding: 0.85rem 1.2rem;
background: var(–header-bg);
color: var(–header-text);
cursor: pointer;
user-select: none;
transition: filter 0.15s;
}
.group-header:hover { filter: brightness(1.15); }

.group-core-swatch {
width: 36px; height: 36px;
border-radius: 6px;
border: 2px solid rgba(255,255,255,0.2);
flex-shrink: 0;
box-shadow: 0 1px 4px rgba(0,0,0,0.3);
}

.group-title {
font-family: ‘Barlow Condensed’, sans-serif;
font-size: 1.05rem; font-weight: 700;
text-transform: uppercase; letter-spacing: 0.08em;
flex: 1;
color: var(–header-text);
}

.group-meta {
font-size: 0.71rem;
color: var(–header-sub);
font-family: ‘Barlow Condensed’, sans-serif;
letter-spacing: 0.04em;
text-align: right; line-height: 1.7;
}

.chevron {
flex-shrink: 0; width: 18px; height: 18px;
opacity: 0.65;
transition: transform 0.25s ease;
color: var(–header-text);
}
.colour-group.open .chevron { transform: rotate(180deg); }

/* ── Collapsible body ── */
.group-body {
display: grid;
grid-template-rows: 0fr;
transition: grid-template-rows 0.28s ease;
}
.colour-group.open .group-body { grid-template-rows: 1fr; }
.group-body-inner { overflow: hidden; }

/* ── Table ── */
.palette-table {
width: 100%;
border-collapse: collapse;
font-size: 0.875rem;
}

.palette-table thead tr { background: var(–th-bg); }

.palette-table thead th {
padding: 0.55rem 1.1rem;
text-align: left;
font-family: ‘Barlow Condensed’, sans-serif;
font-weight: 600; font-size: 0.74rem;
letter-spacing: 0.1em; text-transform: uppercase;
color: var(–th-text);
border-bottom: 1px solid var(–border);
}

.palette-table tbody tr {
border-bottom: 1px solid var(–border);
transition: background 0.12s;
}
.palette-table tbody tr:last-child { border-bottom: none; }
.palette-table tbody tr:hover { background: var(–row-hover); }

.palette-table td {
padding: 0.7rem 1.1rem;
vertical-align: middle;
color: var(–text);
}

/* ── Swatch ── */
.swatch-cell { display: flex; align-items: center; gap: 0.85rem; }

.swatch {
width: 42px; height: 42px;
border-radius: 6px; flex-shrink: 0;
border: 1px solid rgba(128,128,128,0.2);
box-shadow: 0 1px 4px rgba(0,0,0,0.15);
}

.tone-label {
font-family: ‘Barlow Condensed’, sans-serif;
font-size: 0.95rem; font-weight: 600;
letter-spacing: 0.04em;
color: var(–text);
}
.tone-sub { font-size: 0.73rem; color: var(–text-mid); margin-top: 2px; }

/* ── Hex badge ── */
.hex-badge {
display: inline-flex;
align-items: center;
gap: 0.35rem;
font-family: ‘Courier New’, monospace;
font-size: 0.82rem; font-weight: 600;
background: var(–hex-bg);
border: 1px solid var(–hex-border);
border-radius: 4px;
padding: 0.2rem 0.55rem;
color: var(–hex-text);
letter-spacing: 0.05em;
cursor: pointer;
transition: background 0.15s, border-color 0.15s, color 0.15s;
white-space: nowrap;
}
.hex-badge svg { flex-shrink: 0; opacity: 0.4; transition: opacity 0.15s; }
.hex-badge:hover {
background: var(–hex-hover-bg);
border-color: var(–hex-hover-border);
color: var(–hex-hover-text);
}
.hex-badge:hover svg { opacity: 0.7; }
.hex-badge.copied {
background: var(–hex-copied-bg);
border-color: var(–hex-copied-border);
color: var(–hex-copied-text);
}

/* ── Tint bar ── */
.tone-bar-wrap { display: flex; align-items: center; gap: 0.5rem; }
.tone-bar {
height: 8px; border-radius: 4px;
width: 80px; flex-shrink: 0;
border: 1px solid rgba(128,128,128,0.15);
}
.tone-pct { font-size: 0.73rem; color: var(–text-mid); white-space: nowrap; }

/* ── Primary row ── */
.is-primary { background: var(–surface-alt); }
.is-primary td:first-child { border-left: 3px solid var(–primary-mark); }

.code-small { font-family: ‘Courier New’, monospace; font-size: 0.75rem; color: var(–text-mid); }

/* ── Toast ── */
#toast {
position: fixed; bottom: 1.5rem; right: 1.5rem;
background: var(–toast-bg); color: var(–toast-text);
font-family: ‘Barlow’, sans-serif;
font-size: 0.82rem; font-weight: 500;
padding: 0.5rem 1rem; border-radius: 6px;
opacity: 0; pointer-events: none;
transition: opacity 0.2s;
z-index: 999;
box-shadow: 0 4px 16px rgba(0,0,0,0.25);
}
#toast.show { opacity: 1; }

/* ── Footer ── */
footer {
margin-top: 2.5rem; font-size: 0.74rem; color: var(–text-mid);
border-top: 1px solid var(–border); padding-top: 1rem; line-height: 1.8;
}
footer a { color: var(–wmp-blue); }
@media (prefers-color-scheme: dark) { footer a { color: #8ab4e8; } }

@media (max-width: 680px) {
.palette-table thead th:nth-child(4),
.palette-table td:nth-child(4) { display: none; }
.group-meta { display: none; }
body { padding: 1.25rem 0.75rem 3rem; }
}
</style>

