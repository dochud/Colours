<body>

<header>
  <svg class="palette-logo" viewBox="0 0 54 54" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <ellipse cx="27" cy="28" rx="22" ry="20" fill="#004996"/>
    <ellipse cx="35" cy="40" rx="6" ry="5" fill="#f2f2f0"/>
    <circle cx="16" cy="19" r="4.5" fill="#fbba07"/>
    <circle cx="26" cy="14" r="4.5" fill="#e10b29"/>
    <circle cx="36" cy="17" r="4.5" fill="#54a133"/>
    <circle cx="41" cy="27" r="4.5" fill="#ef7a24"/>
    <circle cx="13" cy="30" r="4.5" fill="#7d1c72"/>
    <rect x="22" y="46" width="10" height="5" rx="2.5" fill="#b98a06"/>
  </svg>
  <h1>West Midlands Police
    <span>Official Colour Palette</span>
  </h1>
</header>

<div id="palette-root"></div>
<div id="toast"></div>

<footer>
  Source: <a href="https://identity.west-midlands.police.uk/colour-palette/" target="_blank">identity.west-midlands.police.uk/colour-palette</a>
  &nbsp;·&nbsp; Tonal variants derived by blending toward white in 20% steps
  &nbsp;·&nbsp; CMYK &amp; RGB from Adobe Photoshop (Pantone® solid coated)
  &nbsp;·&nbsp; Click any hex code to copy to clipboard
</footer>

<script>
function hexToRgb(hex) {
  const h = hex.replace('#','');
  return [parseInt(h.slice(0,2),16), parseInt(h.slice(2,4),16), parseInt(h.slice(4,6),16)];
}
function rgbToHex(r,g,b) {
  return '#' + [r,g,b].map(v => Math.round(v).toString(16).padStart(2,'0')).join('');
}
function tint(hex, t) {
  const [r,g,b] = hexToRgb(hex);
  return rgbToHex(r+(255-r)*t, g+(255-g)*t, b+(255-b)*t);
}
function buildTones(hex) {
  return [0,0.2,0.4,0.6,0.8].map((t,i) => ({
    hex: tint(hex,t),
    pct: [100,80,60,40,20][i]+'%',
  }));
}

const toast = document.getElementById('toast');
let toastTimer;
function copyHex(hex, el) {
  navigator.clipboard.writeText(hex).then(() => {
    el.classList.add('copied');
    el.querySelector('.hex-text').textContent = 'Copied!';
    clearTimeout(toastTimer);
    toast.textContent = `${hex} copied to clipboard`;
    toast.classList.add('show');
    toastTimer = setTimeout(() => {
      toast.classList.remove('show');
      el.classList.remove('copied');
      el.querySelector('.hex-text').textContent = hex;
    }, 1800);
  });
}

const clipIcon = `<svg width="11" height="11" viewBox="0 0 16 16" fill="currentColor">
  <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1z"/>
  <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0z"/>
</svg>`;

const chevronSVG = `<svg class="chevron" viewBox="0 0 20 20" fill="currentColor">
  <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/>
</svg>`;

const USES = [
  'Core colour — primary use, headlines, key UI elements',
  'Strong accent, hover / active states, secondary emphasis',
  'Mid-tone accent, dividers, icons, supporting elements',
  'Subtle tint, borders, inactive states, background panels',
  'Very light background wash, card fills, table row tinting',
];

const sections = [
  {
    label: 'Primary Colours',
    colours: [
      { name:'Primary Blue',   nickname:'Core brand blue',   hex:'#004996', pantone:'7687', cmyk:'C100 M72 Y0 K6',  rgb:'R0 G73 B150'    },
      { name:'Primary Yellow', nickname:'Core brand yellow', hex:'#fbba07', pantone:'7408', cmyk:'C0 M30 Y94 K0',   rgb:'R251 G186 B7'   },
    ]
  },
  {
    label: 'Secondary Colours',
    colours: [
      { name:'Red',        nickname:'Pantone 032',  hex:'#e10b29', pantone:'032',  cmyk:'C2 M99 Y83 K0',   rgb:'R225 G11 B41'   },
      { name:'Teal',       nickname:'Pantone 7718', hex:'#0e7181', pantone:'7718', cmyk:'C84 M34 Y37 K18', rgb:'R14 G113 B129'  },
      { name:'Green',      nickname:'Pantone 7741', hex:'#54a133', pantone:'7741', cmyk:'C71 M11 Y100 K1', rgb:'R84 G161 B51'   },
      { name:'Steel Blue', nickname:'Pantone 5425', hex:'#859eb0', pantone:'5425', cmyk:'C52 M28 Y22 K5',  rgb:'R133 G158 B176' },
      { name:'Orange',     nickname:'Pantone 158',  hex:'#ef7a24', pantone:'158',  cmyk:'C0 M61 Y90 K0',   rgb:'R239 G122 B36'  },
      { name:'Purple',     nickname:'Pantone 261',  hex:'#7d1c72', pantone:'261',  cmyk:'C55 M99 Y3 K16',  rgb:'R121 G28 B114'  },
      { name:'Mid Blue',   nickname:'Pantone 660',  hex:'#0379bd', pantone:'660',  cmyk:'C84 M43 Y14 K0',  rgb:'R31 G121 B189'  },
      { name:'Pink',       nickname:'Pantone 204',  hex:'#e97ea7', pantone:'204',  cmyk:'C3 M63 Y8 K0',    rgb:'R231 G158 B167' },
    ]
  },
];

const root = document.getElementById('palette-root');

sections.forEach(section => {
  const labelEl = document.createElement('div');
  labelEl.className = 'section-label';
  labelEl.textContent = section.label;
  root.appendChild(labelEl);

  section.colours.forEach(colour => {
    const group = document.createElement('div');
    group.className = 'colour-group';

    group.innerHTML = `
      <div class="group-header" role="button" aria-expanded="false" tabindex="0">
        <div class="group-core-swatch" style="background:${colour.hex};"></div>
        <div class="group-title">${colour.name}</div>
        <div class="group-meta">Pantone ${colour.pantone} &nbsp;·&nbsp; ${colour.cmyk} &nbsp;·&nbsp; ${colour.rgb}</div>
        ${chevronSVG}
      </div>
      <div class="group-body">
        <div class="group-body-inner">
          <table class="palette-table">
            <thead>
              <tr>
                <th>Swatch &amp; Tone</th>
                <th>Hex</th>
                <th>Tint</th>
                <th>Suggested Use</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    `;

    const hdr = group.querySelector('.group-header');
    hdr.addEventListener('click', () => {
      const open = group.classList.toggle('open');
      hdr.setAttribute('aria-expanded', open);
    });
    hdr.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); hdr.click(); }
    });

    const tbody = group.querySelector('tbody');
    buildTones(colour.hex).forEach((tone, i) => {
      const tr = document.createElement('tr');
      if (i === 0) tr.className = 'is-primary';
      tr.innerHTML = `
        <td>
          <div class="swatch-cell">
            <div class="swatch" style="background:${tone.hex};"></div>
            <div>
              <div class="tone-label">${colour.name} ${tone.pct}</div>
              <div class="tone-sub">${i === 0 ? colour.nickname : tone.pct + ' tint toward white'}</div>
            </div>
          </div>
        </td>
        <td>
          <span class="hex-badge" data-hex="${tone.hex}">
            ${clipIcon}
            <span class="hex-text">${tone.hex}</span>
          </span>
        </td>
        <td>
          <div class="tone-bar-wrap">
            <div class="tone-bar" style="background:${tone.hex};"></div>
            <span class="tone-pct">${tone.pct}</span>
          </div>
        </td>
        <td class="code-small">${USES[i]}</td>
      `;
      tr.querySelector('.hex-badge').addEventListener('click', function() {
        copyHex(tone.hex, this);
      });
      tbody.appendChild(tr);
    });

    root.appendChild(group);
  });
});
</script>

